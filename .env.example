# =============================================================================
# Darboi Consults — Environment variables (server-only, no NEXT_PUBLIC_ prefix)
# Copy to .env.local and add the same keys in Vercel → Settings → Environment Variables
# =============================================================================

# --- REQUIRED: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- REQUIRED: Email (FormSubmit) ---
FORMSUBMIT_EMAIL=darboiconsults@gmail.com
# Optional: FormSubmit AJAX key (from formsubmit.co after confirming email)
# FORMSUBMIT_ACCESS_KEY=
# Recommended fallback when FormSubmit blocks server emails — Gmail App Password:
# https://myaccount.google.com/apppasswords
# GMAIL_APP_PASSWORD=your-16-char-app-password
# SMTP_USER=darboiconsults@gmail.com

# --- REQUIRED: Google Form ---
GOOGLE_FORM_URL=https://forms.gle/your-form-id

# --- REQUIRED: Admin login (/admin/login) ---
ADMIN_EMAIL=darboiconsults@gmail.com
ADMIN_PASSWORD=your-strong-password
ADMIN_SESSION_SECRET=use-a-long-random-string-min-32-chars

# --- RECOMMENDED: Production ---
SITE_URL=https://travel-tours-eight.vercel.app

# --- RECOMMENDED: Payments (public keys — loaded via /api/payment-keys at checkout) ---
PAYSTACK_PUBLIC_KEY=pk_live_or_pk_test_xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxx

# --- OPTIONAL ---
SHOW_PRICING=false
GA_MEASUREMENT_ID=
