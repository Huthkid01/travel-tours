# =============================================================================
# Copy this file to .env.local (local dev) and add the same keys in Vercel →
# Settings → Environment Variables. Replace placeholder values with your real keys.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Supabase (saves applications + file uploads)
# Get from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# REQUIRED — Email to you (FormSubmit — NOT EmailJS)
# Messages from Contact form + application notifications go here.
# First submit on live site → click activation link in inbox once.
# https://formsubmit.co
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FORMSUBMIT_EMAIL=darboiconsults@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=darboiconsults@gmail.com

# -----------------------------------------------------------------------------
# REQUIRED — Google Form (consultation form after “Allow cookies”)
# Use your forms.gle link (same as embed on site)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_FORM_URL=https://forms.gle/CgsEKQ8JudSTRaVY9

# -----------------------------------------------------------------------------
# Site (recommended for production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=Darboi Consults Limited
NEXT_PUBLIC_SITE_URL=https://travel-tours-eight.vercel.app
NEXT_PUBLIC_ADMIN_PHONE=08038178843
NEXT_PUBLIC_WHATSAPP_NUMBER=2348038178843

# -----------------------------------------------------------------------------
# Payments (use live keys when ready; demo keys work for testing)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx

# -----------------------------------------------------------------------------
# Homepage video
# File is at public/video/featured.mp4 — change only if you use another path
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TIKTOK_VIDEO_URL=https://www.tiktok.com/t/ZP8p44v1g/
NEXT_PUBLIC_FEATURED_VIDEO_SRC=/video/featured.mp4

# -----------------------------------------------------------------------------
# Social (optional — TikTok is used in footer & video section)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@darboiconsults
NEXT_PUBLIC_TIKTOK_HANDLE=@darboiconsults

# -----------------------------------------------------------------------------
# Admin dashboard (server-only — never expose password in NEXT_PUBLIC_*)
# Login at /admin/login — manage programs, announcements, view visits & applications
# -----------------------------------------------------------------------------
ADMIN_EMAIL=darboiconsults@gmail.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SESSION_SECRET=generate-a-long-random-string-here

# Supabase service role — Dashboard → Settings → API → service_role (secret)
# Required for admin to edit programs/announcements and read all data
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SHOW_PRICING=false
NEXT_PUBLIC_SHOW_PRICES=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# DEPRECATED — do not use (site uses FormSubmit above)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
