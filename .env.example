# =============================================================================
# Darboi Consults — Environment variables (server-only, no NEXT_PUBLIC_ prefix)
# Copy to .env.local and add the same keys in Vercel → Settings → Environment Variables
# =============================================================================

# --- REQUIRED: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- REQUIRED: Owner email (Gmail + Nodemailer) ---
# Sender (Google account with App Password):
SMTP_USER=darboiconsults717@gmail.com
# Inbox that receives form notifications:
OWNER_INBOX_EMAIL=darboiconsults@gmail.com
# App password from https://myaccount.google.com/apppasswords (no spaces)
GMAIL_APP_PASSWORD=your-16-character-app-password

# --- REQUIRED: Google Form ---
GOOGLE_FORM_URL=https://forms.gle/your-form-id

# --- REQUIRED: Admin login (/admin/login) ---
ADMIN_EMAIL=darboiconsults@gmail.com
ADMIN_PASSWORD=your-strong-password
ADMIN_SESSION_SECRET=use-a-long-random-string-min-32-chars

# --- RECOMMENDED: Production ---
SITE_URL=https://www.darboiconsults.com
# Google Search Console → HTML tag method (content value only, not the full meta tag)
GOOGLE_SITE_VERIFICATION=O0J-YJ_IRPkluzgrmCt5F6-_1gc2-MU73vtCDkzpZhQ

# --- RECOMMENDED: Payments (public keys — loaded via /api/payment-keys at checkout) ---
PAYSTACK_PUBLIC_KEY=pk_live_or_pk_test_xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxx

# --- OPTIONAL ---
SHOW_PRICING=false
GA_MEASUREMENT_ID=
